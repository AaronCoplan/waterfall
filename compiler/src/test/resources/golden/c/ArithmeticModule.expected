// module ArithmeticModule
#include <stdio.h>
#include <stdbool.h>
#include <string.h>

int sumOfMultiples(int limit) {
    int total = 0;
    int n = 0;
    while ((n < limit)) {if ((((n % 3) == 0) || ((n % 5) == 0))) {total += n;}
n++;}
    return total;
}

int square(int x) {
    return (x * x);
}

int cube(int x) {
    return pow(x, 3);
}

